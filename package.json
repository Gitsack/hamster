    "@storybook/react-vite": "^10.2.19",
    "@swc/core": "^1.15.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/luxon": "^3.7.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.15",
