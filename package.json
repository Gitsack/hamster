    "@vinejs/vine": "^4.3.0",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "edge.js": "^6.5.0",
    "fast-xml-parser": "^5.5.5",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.562.0",
    "luxon": "^3.7.2",
    "mime-types": "^3.0.2",
    "music-metadata": "^11.12.3",
    "next-themes": "^0.4.6",
